# Copy this file to .env and fill in the values
# NEVER commit .env to git

# Gmail App Password for E153.manager@gmail.com
# Generate at: myaccount.google.com → Security → 2-Step Verification → App passwords
# Select "Mail" + "Mac" and copy the 16-char password (spaces are fine)
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Anthropic API key
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# GitHub fine-grained token (Contents read+write on school-dashboard repo only)
# Get from: github.com/settings/tokens → Fine-grained tokens
GITHUB_TOKEN=github_pat_...
